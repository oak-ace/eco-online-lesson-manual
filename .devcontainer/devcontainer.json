// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Playwright Dev Container",
	"image": "mcr.microsoft.com/playwright",
	"features": {
		"ghcr.io/devcontainers/features/aws-cli:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/python:1": {}
	},
	"containerEnv": {
		"E2E_TEACHER_EMAIL": "${localEnv:E2E_TEACHER_EMAIL:teacher@ace-software.com}",
		"E2E_PARENT_EMAIL": "${localEnv:E2E_PARENT_EMAIL:parent@ace-software.com}",
		"E2E_LOGIN_PASSWORD": "${localEnv:E2E_LOGIN_PASSWORD:}"
	},
	"mounts": [
		// AWS CLI 用（ホスト共有でOK）
		"source=${localEnv:HOME}/.aws,target=/home/node/.aws,type=bind,consistency=cached",
		// GPG 用（Docker volume）
		"source=devcontainer-gnupg,target=/home/node/.gnupg,type=volume",
		// CodeX 用（ホスト共有でOK）
		"source=${localEnv:HOME}/.codex/eco-online-lesson-manual,target=/root/.codex,type=bind,consistency=cached"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"openai.chatgpt",
				"mhutchie.git-graph"
			]
		}
	},
	"hostRequirements": {
		"cpus": 2,
		"memory": "4gb"
	},
	"runArgs": [
		"--ipc=host" // ブラウザのクラッシュ防止に必須
	],
	"postCreateCommand": "pip3 install playwright && playwright install --with-deps"
}