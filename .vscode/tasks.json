{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AWS: SSO Login",
      "type": "shell",
      "command": "aws",
      "args": [
        "sso",
        "login",
        "--profile",
        "${env:AWS_PROFILE}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
