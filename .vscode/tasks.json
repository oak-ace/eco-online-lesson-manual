{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AWS: SSO Login",
      "type": "shell",
      "command": "aws",
      "args": [
        "sso",
        "login",
        "--profile",
        "${env:AWS_PROFILE}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "GitHub: Login",
      "type": "shell",
      "command": "gh",
      "args": [
        "auth",
        "login"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Manual: Generate",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "generate:manual"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
